pipeline {
    agent any

    parameters {
        choice(
            name: 'DEPLOY_ENV',
            choices: ['dev', 'qa', 'prod'],
            description: 'Select target deployment environment'
        )
    }

    environment {
        AWS_REGION = 'us-east-1'
        ECR_REPO = '484826611947.dkr.ecr.us-east-1.amazonaws.com/enterprise-product-app'
        IMAGE_TAG = "${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Maven Build') {
            steps {
                dir('app') {
                    sh 'mvn clean package'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('app') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=enterprise-product-app \
                        -Dsonar.projectName=enterprise-product-app
                        '''
                    }
                }
            }
        }

        stage('Retrieve Secret From AWS Secrets Manager') {
            steps {
                sh '''
                aws secretsmanager get-secret-value \
                --secret-id enterprise-product-db-password \
                --region ${AWS_REGION} \
                --query SecretString \
                --output text
                '''
            }
        }

        stage('Archive Artifact') {
            steps {
                archiveArtifacts artifacts: 'app/target/*.jar'
            }
        }

        stage('Docker Build') {
            steps {
                sh '''
                docker build \
                -t enterprise-product-app:${IMAGE_TAG} \
                -f product-docker/Dockerfile .
                '''
            }
        }

        stage('ECR Login') {
            steps {
                sh '''
                aws ecr get-login-password --region ${AWS_REGION} | \
                docker login --username AWS \
                --password-stdin ${ECR_REPO}
                '''
            }
        }

        stage('Push To ECR') {
            steps {
                sh '''
                docker tag enterprise-product-app:${IMAGE_TAG} \
                ${ECR_REPO}:${IMAGE_TAG}

                docker push ${ECR_REPO}:${IMAGE_TAG}
                '''
            }
        }

        stage('Deploy To Selected Environment') {
            steps {
                sh '''
                echo "Deploying to environment: ${DEPLOY_ENV}"
                echo "Using image tag: ${IMAGE_TAG}"

                chmod +x product-deployment-pipeline/scripts/render-deployment.sh

                OVERRIDE_IMAGE_TAG=${IMAGE_TAG} \
                ./product-deployment-pipeline/scripts/render-deployment.sh ${DEPLOY_ENV}

                aws eks update-kubeconfig --region ${AWS_REGION} --name enterprise-product-eks

                kubectl create namespace ${DEPLOY_ENV} --dry-run=client -o yaml | kubectl apply -f -

                kubectl apply -f product-kubernetes/rendered/${DEPLOY_ENV}/

                kubectl rollout status deployment/enterprise-product-app -n ${DEPLOY_ENV}

                kubectl get pods -n ${DEPLOY_ENV}
                kubectl get svc -n ${DEPLOY_ENV}
                '''
            }
        }
    }
}